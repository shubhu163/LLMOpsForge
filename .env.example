# LLMOpsForge environment configuration.
# Copy to .env and adjust. NOTHING here is required to run locally with the
# default MockLLMProvider — every value below has a safe default.

# --- Core ---
LLMOPS_DATABASE_URL=sqlite:///./data/llmopsforge.db
LLMOPS_DATA_DIR=./data
LLMOPS_LOG_LEVEL=INFO

# --- Default provider/model (mock = zero-cost, deterministic) ---
LLMOPS_DEFAULT_PROVIDER=mock
LLMOPS_DEFAULT_MODEL=mock-small

# --- Embeddings ---
# If sentence-transformers is installed this model is used; otherwise a
# deterministic hashing embedder is used automatically.
LLMOPS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Optional: OpenAI provider (only needed if you set provider=openai) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Optional: Ollama provider (local models) ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- Optional: OpenRouter (RECOMMENDED for real RAG) ---
# One key -> many real models (GPT, Claude, Llama, Gemini) incl. FREE ones.
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_TITLE=LLMOpsForge
